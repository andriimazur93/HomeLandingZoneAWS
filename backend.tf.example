# Copy this file to backend.tfbackend and fill in your values.
# This file is gitignored and should NEVER be committed to version control.
#
# After running `terraform apply` for the first time, populate these
# values from the Terraform outputs, then run:
#   terraform init -backend-config=backend.tfbackend

bucket       = "homelab-tfstate-ACCOUNT_ID-REGION"
key          = "home-landing-zone/terraform.tfstate"
region       = "REGION"
use_lockfile = true
encrypt      = true
